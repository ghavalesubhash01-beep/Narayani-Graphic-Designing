<!DOCTYPE html>
<html lang="mr">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>नारायणी ग्राफिक्स डिझायनिंग</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

body{
margin:0;
font-family:'Poppins',sans-serif;
background:#f5f5f5;
}

/* NAVBAR */
nav{
background:#111;
color:white;
display:flex;
justify-content:space-between;
padding:15px 20px;
position:sticky;
top:0;
}

nav a{
color:white;
text-decoration:none;
margin:0 10px;
}

/* HERO */
.hero{
background:linear-gradient(135deg,#667eea,#764ba2);
color:white;
text-align:center;
padding:60px 20px;
}

/* SEARCH */
.search{
margin-top:20px;
}

.search input{
padding:10px;
width:200px;
}

/* CATEGORY */
.categories{
margin-top:15px;
}

.cat{
display:inline-block;
background:#eee;
padding:8px 15px;
margin:5px;
border-radius:20px;
cursor:pointer;
}

/* CONTAINER */
.container{
max-width:1100px;
margin:auto;
padding:20px;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

/* CARD */
.card{
background:white;
border-radius:10px;
overflow:hidden;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.card img{
width:100%;
}

.info{
padding:15px;
}

.price{
color:red;
}

.btn{
display:block;
margin-top:10px;
background:#25D366;
color:white;
padding:10px;
text-align:center;
border-radius:5px;
text-decoration:none;
}

/* FORM */
form{
background:white;
padding:20px;
border-radius:10px;
}

input,select{
width:100%;
padding:10px;
margin:10px 0;
}

/* PAYMENT */
.payment{
background:white;
padding:20px;
margin-top:20px;
text-align:center;
border-radius:10px;
}

/* TESTIMONIAL */
.testimonial{
background:white;
padding:20px;
margin-top:20px;
border-radius:10px;
text-align:center;
}

/* FOOTER */
footer{
background:#111;
color:white;
text-align:center;
padding:15px;
}

</style>

</head>

<body>

<!-- NAVBAR -->
<nav>
<div>नारायणी ग्राफिक्स</div>
<div>
<a href="#shop">Shop</a>
<a href="#order">Order</a>
<a href="#contact">Contact</a>
</div>
</nav>

<!-- HERO -->
<div class="hero">
<h1>✨ तुमच्या कल्पनेला आमच्या कलेचा स्पर्श ✨</h1>
<p>Professional Graphic Designing Services</p>

<div class="search">
<input type="text" id="search" placeholder="Search design...">
</div>

<div class="categories">
<span class="cat" onclick="filter('all')">All</span>
<span class="cat" onclick="filter('birthday')">Birthday</span>
<span class="cat" onclick="filter('wedding')">Wedding</span>
</div>

</div>

<!-- PRODUCTS -->
<div class="container" id="shop">

<div class="grid" id="products">

<div class="card" data-cat="birthday">
<img src="design1.jpg">
<div class="info">
<h3>Birthday Banner</h3>
<p class="price">₹99</p>
<a class="btn" href="https://wa.me/918830552937?text=Birthday Banner हवा आहे">Buy</a>
</div>
</div>

<div class="card" data-cat="wedding">
<img src="design2.jpg">
<div class="info">
<h3>Wedding Card</h3>
<p class="price">₹199</p>
<a class="btn" href="https://wa.me/918830552937?text=Wedding Card हवा आहे">Buy</a>
</div>
</div>

</div>

</div>

<!-- ORDER FORM -->
<div class="container" id="order">

<h2>📦 Order Form</h2>

<form onsubmit="sendOrder(event)">

<input type="text" id="name" placeholder="तुमचं नाव" required>
<input type="text" id="design" placeholder="कुठला डिझाईन हवा?" required>
<input type="text" id="details" placeholder="डिटेल्स लिहा" required>

<button class="btn">Submit Order</button>

</form>

</div>

<!-- PAYMENT -->
<div class="container">

<div class="payment">
<h2>💳 Payment</h2>
<p>UPI / GPay / PhonePe</p>
<p><b>8010998651</b></p>
<a class="btn" href="upi://pay?pa=8010998651@upi&pn=Narayani">Pay Now</a>
</div>

</div>

<!-- TESTIMONIAL -->
<div class="container">

<div class="testimonial">
<p>“खूप सुंदर डिझाईन! ⭐⭐⭐⭐⭐”</p>
</div>

</div>

<footer id="contact">
<p>📲 WhatsApp: 8830552937</p>
</footer>

<script>

function filter(cat){
let items=document.querySelectorAll(".card");
items.forEach(i=>{
i.style.display=(cat=="all"||i.dataset.cat==cat)?"block":"none";
});
}

function sendOrder(e){
e.preventDefault();
let name=document.getElementById("name").value;
let design=document.getElementById("design").value;
let details=document.getElementById("details").value;

let msg=`Name: ${name} Design: ${design} Details: ${details}`;
window.open(`https://wa.me/918830552937?text=${msg}`);
}

</script>

</body>
</html>
